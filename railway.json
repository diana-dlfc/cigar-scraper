{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python -c \"import os; open('/tmp/credentials.json','w').write(os.environ['GOOGLE_SHEETS_CREDENTIALS_JSON'])\" && python pipeline/orchestrator.py",
    "restartPolicyType": "ON_FAILURE"
  }
}